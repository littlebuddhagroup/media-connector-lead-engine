# ============================================
# MEDIA CONNECTOR LEAD ENGINE — Variables de entorno
# Copia este archivo como .env.local y rellena los valores
# ============================================

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# --- OPENAI ---
OPENAI_API_KEY=sk-...

# --- RESEND (Email) ---
RESEND_API_KEY=re_...
# Email desde el que se envían los correos (debe estar verificado en Resend)
RESEND_FROM_EMAIL=leads@tudominio.com
RESEND_FROM_NAME=Media Connector

# --- SERPAPI (Scraping Google Search) ---
SERPAPI_API_KEY=tu-serpapi-key

# --- HUNTER.IO (Enriquecimiento de emails) ---
HUNTER_API_KEY=tu-hunter-key

# --- APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Límite de emails por día (seguridad)
DAILY_EMAIL_LIMIT=50

# --- OPCIONAL: otros proveedores de scraping ---
# APIFY_API_KEY=tu-apify-key
# CLEARBIT_API_KEY=tu-clearbit-key
